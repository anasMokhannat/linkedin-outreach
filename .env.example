# ---------------------------------------------------------------------------
# Public
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Base URL of the app (OpenRouter attribution).
APP_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Supabase server-only
# ---------------------------------------------------------------------------
# Service role key — SERVER ONLY. Used for all DB access (identity is the signed
# session cookie, not Supabase Auth) AND as the HMAC key that signs the session
# cookie. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Unipile (managed LinkedIn API) — connect, sync, enrichment, sending
# ---------------------------------------------------------------------------
# DSN = base URL from the Unipile dashboard, e.g. api8.unipile.com:13443
UNIPILE_DSN=
UNIPILE_API_KEY=

# ---------------------------------------------------------------------------
# OpenRouter (AI message generation)
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

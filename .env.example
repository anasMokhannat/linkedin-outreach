# ---------------------------------------------------------------------------
# Public (safe to expose to the browser)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base URL of the deployed app (used for Apify webhook + OpenRouter attribution).
APP_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Supabase server-only
# ---------------------------------------------------------------------------
# Service role key — SERVER ONLY. Bypasses RLS; never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# 32-byte base64 key for the app-level AES fallback (Vault is the primary path).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
COOKIE_ENC_KEY=

# ---------------------------------------------------------------------------
# LinkedIn provider selection
# ---------------------------------------------------------------------------
# Which provider powers connection-fetch + DM-send:
#   apify        -> cookie-based Apify actors (default, fully implemented)
#   linkedin-api -> official LinkedIn API (partner-gated; stubbed until wired)
LINKEDIN_PROVIDER=apify

# ---------------------------------------------------------------------------
# Apify  (used when LINKEDIN_PROVIDER=apify)
# ---------------------------------------------------------------------------
APIFY_TOKEN=
# Shared secret echoed back on the run webhook; verified in /api/webhooks/apify.
APIFY_WEBHOOK_SECRET=

# Actor IDs are CONFIG (never hardcoded). Swap primary<->backup without code changes.
APIFY_ACTOR_CONNECTIONS=     # cookie-based: fetch 1st-degree connections
APIFY_ACTOR_PROFILE=         # cookieless: profile enrichment
APIFY_ACTOR_POSTS=           # cookieless: recent posts
APIFY_ACTOR_COMPANY=         # cookieless: company page (OPTIONAL — leave blank to skip)
APIFY_ACTOR_SEND_DM=         # cookie-based: send a 1st-degree DM

# ---------------------------------------------------------------------------
# OpenRouter
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
# Default model; users may override per-account in Settings.
OPENROUTER_MODEL=openai/gpt-4o-mini

# ---------------------------------------------------------------------------
# Cron / scheduling
# ---------------------------------------------------------------------------
# Protects /api/cron/*. Vercel Cron sends "Authorization: Bearer $CRON_SECRET".
CRON_SECRET=
# Optional Upstash QStash token for precise delayed delivery (not required).
QSTASH_TOKEN=

# ---------------------------------------------------------------------------
# Dev-only auth bypass (NEVER set to true in production)
# ---------------------------------------------------------------------------
# When 'true', the login page shows a "Dev login (no LinkedIn)" button that
# signs in a local test user via the Supabase admin API — lets you use the app
# without configuring any external auth provider. Leave blank/unset in prod.
NEXT_PUBLIC_DEV_AUTH=
